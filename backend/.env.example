## Backend (local)
# Porta do server
PORT=8080

# URL do Postgres (Cloud SQL / local). Ex:
# postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agilis?schema=public

# CORS (frontend). Ex: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Allowlist simples de admins (MVP). Separado por vírgula.
ADMIN_EMAILS=admin@exemplo.com

# GCP project (opcional; o Admin SDK pega via ADC)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

